<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Belajar Kedokteran</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 antialiased">

    <header class="bg-white shadow-sm sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <svg class="w-9 h-9 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">E-Belajar <span class="text-teal-600">Kedokteran</span></h1>
            </div>
            <span class="text-sm font-semibold text-teal-700 bg-teal-50 px-3 py-1 rounded-full">Drive Otomatis</span>
        </nav>
    </header>

    <main class="max-w-7xl mx-auto p-6 md:p-8">
        
        <div class="bg-white p-8 rounded-2xl shadow-lg border-t-4 border-teal-500 mb-8">
            <h2 class="text-4xl font-bold text-gray-950 tracking-tight">Materi Drive Saya</h2>
            <p class="text-gray-500 mt-2">Daftar di bawah ini akan terupdate otomatis setiap kali Anda menambah file/folder di Google Drive.</p>
        </div>

        <div id="grid-materi" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            <div class="col-span-full text-center py-12">
                <p class="text-gray-500 animate-pulse font-medium">Sedang mengambil data terbaru dari Google Drive...</p>
            </div>
        </div>
    </main>

    <script>
        // === GANTI KEDUA VARIABEL INI ===
        const API_KEY = 'AIzaSyCrzY5htjG_Q5NE5RIbtvp4ObHU5L3PWZo'; 
        const FOLDER_ID = '1tdmUCgVhsvp4ADXL1mjPv5qx_cidolbL'; 

        async function ambilDataDrive() {
            // URL API untuk meminta daftar file di dalam folder utama
            const url = `https://www.googleapis.com/drive/v3/files?q='${FOLDER_ID}'+in+parents+and+trashed=false&key=${API_KEY}&fields=files(id,name,mimeType)&orderBy=name`;
            
            try {
                const response = await fetch(url);
                const data = await response.json();
                
                if (data.error) {
                    document.getElementById('grid-materi').innerHTML = `<p class="text-red-500 col-span-full text-center">Error: ${data.error.message}. Pastikan folder Drive sudah di-share ke 'Anyone with link'</p>`;
                    return;
                }

                tampilkanKeWeb(data.files);
            } catch (error) {
                console.error("Gagal mengambil data:", error);
            }
        }

        function tampilkanKeWeb(files) {
            const container = document.getElementById('grid-materi');
            container.innerHTML = ''; // Hapus tulisan loading

            if (!files || files.length === 0) {
                container.innerHTML = '<p class="text-gray-500 col-span-full text-center">Folder kosong.</p>';
                return;
            }

            files.forEach(file => {
                let ikon = '';
                let warnaIkon = '';
                let badgeText = 'File';

                // Deteksi tipe file/folder untuk menentukan ikon & warna bertema medis
                if (file.mimeType === 'application/vnd.google-apps.folder') {
                    ikon = `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>`;
                    warnaIkon = 'bg-teal-50 text-teal-600';
                    badgeText = 'Folder';
                } else if (file.mimeType.includes('video')) {
                    ikon = `<svg class="w-7 h-7" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"></path></svg>`;
                    warnaIkon = 'bg-red-50 text-red-600';
                    badgeText = 'Video';
                } else {
                    ikon = `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>`;
                    warnaIkon = 'bg-blue-50 text-blue-600';
                    badgeText = 'Dokumen';
                }

                // Link akses langsung ke Google Drive
                const linkAkses = file.mimeType === 'application/vnd.google-apps.folder' 
                    ? `https://drive.google.com/drive/folders/${file.id}`
                    : `https://drive.google.com/file/d/${file.id}/view`;

                // Render kartu HTML
                const kartuHtml = `
                    <div class="bg-white rounded-2xl shadow-md hover:shadow-xl transition duration-300 p-6 flex flex-col justify-between group">
                        <div>
                            <div class="flex items-center space-x-4">
                                <div class="p-3 ${warnaIkon} rounded-lg group-hover:scale-105 transition">
                                    ${ikon}
                                </div>
                                <div class="overflow-hidden">
                                    <span class="text-xs font-semibold text-gray-500 bg-gray-100 px-2 py-0.5 rounded">${badgeText}</span>
                                    <h3 class="font-bold text-gray-900 text-base mt-1 leading-tight truncate" title="${file.name}">${file.name}</h3>
                                </div>
                            </div>
                        </div>
                        <a href="${linkAkses}" target="_blank" class="mt-6 inline-block w-full text-center bg-teal-500 hover:bg-teal-600 text-white font-semibold py-2.5 rounded-xl transition duration-150 text-sm">Buka Materi</a>
                    </div>
                `;
                container.innerHTML += kartuHtml;
            });
        }

        // Jalankan fungsi
        ambilDataDrive();
    </script>
</body>
</html>
